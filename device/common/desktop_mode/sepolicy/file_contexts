# Desktop Mode File Contexts
# Maps files to their SELinux security contexts

# Desktop Launcher app
/system_ext/priv-app/DesktopLauncher(/.*)? u:object_r:system_exec:s0

# Desktop mode daemon executable
/system/bin/desktopd u:object_r:desktop_mode_service_exec:s0

# Desktop mode data directory
/data/local/tmp/desktop_mode(/.*)? u:object_r:desktop_mode_service_data_file:s0

# Desktop mode socket
/dev/socket/desktop_mode(/.*)? u:object_r:desktop_mode_service:s0
