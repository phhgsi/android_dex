<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/settingsToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:title="@string/settings"
        app:titleTextColor="@color/text_primary"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@color/text_primary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_medium">

            <!-- Grid Settings Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/grid_settings"
                android:textColor="@color/accent"
                android:textSize="@dimen/text_medium"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/spacing_small" />

            <!-- Grid Columns -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/spacing_small">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/grid_columns"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_medium" />

                <Spinner
                    android:id="@+id/gridColumnsSpinner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/accent"
                    android:padding="@dimen/spacing_small" />

            </LinearLayout>

            <!-- Show System Apps -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/spacing_small">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/show_system_apps"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_medium" />

                <Switch
                    android:id="@+id/showSystemAppsSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:onClick="onShowSystemAppsChanged" />

            </LinearLayout>

            <!-- Sort Order -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/spacing_small">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/sort_order"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_medium" />

                <Spinner
                    android:id="@+id/sortOrderSpinner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/accent"
                    android:padding="@dimen/spacing_small" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginVertical="@dimen/spacing_medium" />

            <!-- Behavior Settings Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/behavior_settings"
                android:textColor="@color/accent"
                android:textSize="@dimen/text_medium"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/spacing_small" />

            <!-- Dark Theme -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/spacing_small">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/dark_theme"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_medium" />

                <Switch
                    android:id="@+id/darkThemeSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:onClick="onDarkThemeChanged" />

            </LinearLayout>

            <!-- Auto Launch in Window -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/spacing_small">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/auto_launch"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_medium" />

                <Switch
                    android:id="@+id/autoLaunchSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:onClick="onAutoLaunchChanged" />

            </LinearLayout>

            <!-- Window Animation -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/spacing_small">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/window_animation"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_medium" />

                <Switch
                    android:id="@+id/windowAnimationSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:onClick="onWindowAnimationChanged" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginVertical="@dimen/spacing_medium" />

            <!-- Reset to Defaults -->
            <Button
                android:id="@+id/resetButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reset_to_defaults"
                android:onClick="onResetToDefaults"
                style="@style/Widget.Material3.Button.TextButton" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginVertical="@dimen/spacing_medium" />

            <!-- About Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/about"
                android:textColor="@color/accent"
                android:textSize="@dimen/text_medium"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/spacing_small" />

            <TextView
                android:id="@+id/versionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_small" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
