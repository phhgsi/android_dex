<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/desk_window_background">

    <!-- Title Bar -->
    <LinearLayout
        android:id="@+id/window_title_bar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@drawable/desk_title_bar_background"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- App Icon -->
        <ImageView
            android:id="@+id/window_app_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="12dp"
            android:scaleType="fitCenter"
            android:contentDescription="@string/desk_window_app_icon_desc" />

        <!-- Window Title -->
        <TextView
            android:id="@+id/window_title_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <!-- Window Controls -->
        <ImageButton
            android:id="@+id/btn_window_minimize"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/desk_window_minimize_desc"
            android:padding="10dp"
            android:src="@drawable/ic_desk_window_minimize" />

        <ImageButton
            android:id="@+id/btn_window_maximize"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/desk_window_maximize_desc"
            android:padding="10dp"
            android:src="@drawable/ic_desk_window_maximize" />

        <ImageButton
            android:id="@+id/btn_window_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="4dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/desk_window_close_desc"
            android:padding="10dp"
            android:src="@drawable/ic_desk_window_close" />

    </LinearLayout>

    <!-- Content Container (where the app window content goes) -->
    <FrameLayout
        android:id="@+id/window_content_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="40dp" />

    <!-- Resize Handles -->
    <!-- Left edge -->
    <View
        android:id="@+id/resize_handle_left"
        android:layout_width="16dp"
        android:layout_height="match_parent"
        android:layout_marginTop="40dp"
        android:layout_gravity="start"
        android:background="@drawable/desk_resize_handle_vertical" />

    <!-- Top edge -->
    <View
        android:id="@+id/resize_handle_top"
        android:layout_width="match_parent"
        android:layout_height="16dp"
        android:layout_gravity="top"
        android:background="@drawable/desk_resize_handle_horizontal" />

    <!-- Right edge -->
    <View
        android:id="@+id/resize_handle_right"
        android:layout_width="16dp"
        android:layout_height="match_parent"
        android:layout_marginTop="40dp"
        android:layout_gravity="end"
        android:background="@drawable/desk_resize_handle_vertical" />

    <!-- Bottom edge -->
    <View
        android:id="@+id/resize_handle_bottom"
        android:layout_width="match_parent"
        android:layout_height="16dp"
        android:layout_gravity="bottom"
        android:background="@drawable/desk_resize_handle_horizontal" />

    <!-- Top-left corner -->
    <View
        android:id="@+id/resize_handle_top_left"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="top|start"
        android:layout_marginTop="40dp"
        android:background="@drawable/desk_resize_handle_corner" />

    <!-- Top-right corner -->
    <View
        android:id="@+id/resize_handle_top_right"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="40dp"
        android:background="@drawable/desk_resize_handle_corner" />

    <!-- Bottom-left corner -->
    <View
        android:id="@+id/resize_handle_bottom_left"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="bottom|start"
        android:background="@drawable/desk_resize_handle_corner" />

    <!-- Bottom-right corner -->
    <View
        android:id="@+id/resize_handle_bottom_right"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="bottom|end"
        android:background="@drawable/desk_resize_handle_corner" />

</FrameLayout>
