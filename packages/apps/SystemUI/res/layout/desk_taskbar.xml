<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/desk_taskbar_layout"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:background="#1A1A2E"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:elevation="8dp">

    <!-- Home Button -->
    <ImageButton
        android:id="@+id/desk_home_button"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/desk_home_button_desc"
        android:padding="16dp"
        android:src="@drawable/ic_desk_taskbar_home" />

    <!-- Running Apps - Horizontal Scroll -->
    <HorizontalScrollView
        android:id="@+id/desk_apps_scroll"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:scrollbars="none"
        android:fadingEdge="horizontal"
        android:fadingEdgeLength="24dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/desk_apps_recycler"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    </HorizontalScrollView>

    <!-- System Tray -->
    <com.android.systemui.desktop.DesktopSystemTray
        android:id="@+id/desk_system_tray"
        android:layout_width="wrap_content"
        android:layout_height="56dp" />

</LinearLayout>
